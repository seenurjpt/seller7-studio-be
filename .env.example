# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/seller7-studio

# Frontend (for reset-password links, CORS)
CLIENT_URL=http://localhost:3000
# Comma-separated allowlist of browser origins. Must NOT be '*' because the API
# uses credentials (cookies). Add every frontend origin, e.g.:
# CORS_ORIGIN=http://localhost:3000,https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Password Reset
RESET_TOKEN_EXPIRES_MIN=15

# Razorpay (get keys from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Set after creating a webhook in the Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=

# SMTP (leave blank in dev to use Ethereal/console logging)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Seller7 Studio <no-reply@seller7.studio>"
